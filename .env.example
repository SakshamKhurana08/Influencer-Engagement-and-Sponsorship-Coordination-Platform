# =============================================================================
#  InSync — Frontend Environment Variables
#  Copy to .env.local for local overrides or .env.production.local for prod.
#  Vite only exposes variables prefixed with VITE_ to the browser bundle.
# =============================================================================

# ─── API base URL ─────────────────────────────────────────────────────────────
# Development: leave unset — Vite proxy forwards /api/* to Flask automatically.
# Production:  set to your deployed Flask API origin.
# VITE_API_URL=https://api.yourdomain.com
