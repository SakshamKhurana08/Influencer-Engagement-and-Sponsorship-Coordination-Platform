# ─── Flask Core ───────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL (production / default)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/influencer_db

# SQLite fallback — used automatically if DATABASE_URL is not set
# DATABASE_URL=sqlite:///influencer_dev.db

# ─── File Uploads ─────────────────────────────────────────────
UPLOAD_FOLDER=uploads/influencer_photos
MAX_CONTENT_LENGTH=10485760

# ─── Admin seed credentials ───────────────────────────────────
ADMIN_EMAIL=admin@insync.dev
ADMIN_PASSWORD=Admin@1234

# ─── App port ─────────────────────────────────────────────────
PORT=5000
